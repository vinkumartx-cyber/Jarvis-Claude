# Next.js & Authentication
NEXTAUTH_SECRET=your_nextauth_secret_key_here_change_in_production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_PROVIDERS_DEBUG=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_POSTGRES_PASSWORD=your_postgres_password_here

# AI & Language Models
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Text-to-Speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here_default_voice

# Telephony
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_SECRET=your_twilio_webhook_secret_here

# QuickBooks Online
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id_here
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret_here
QUICKBOOKS_REALM_ID=your_quickbooks_realm_id_here
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/oauth/quickbooks/callback

# Calendar Integration
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here

# Cron Jobs & Scheduled Tasks
CRON_SECRET=your_cron_secret_key_here_for_vercel_crons

# Feature Flags
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_VIDEO=false
NEXT_PUBLIC_ENABLE_CALENDAR=true
NEXT_PUBLIC_ENABLE_QUICKBOOKS=true

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Vinesh AI Assistant
NEXT_PUBLIC_APP_DESCRIPTION=Your voice-first AI personal assistant

# Analytics & Monitoring (Optional)
NEXT_PUBLIC_MIXPANEL_TOKEN=
SENTRY_DSN=

# Development
DEBUG=false
